        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.colors import ListedColormap\n",
        "from sklearn.tree import DecisionTreeClassifier\n",
        "\n",
        "# 1. Assuming you have df from 'australian_property_regression.csv' loaded\n",
        "# Let's use the two most impactful columns for our 2D visualization\n",
        "X_visual = data[['Distance_to_CBD_KM', 'Floor_Area_SqM']].values\n",
        "\n",
        "# 2. Convert the continuous target (Property Value) into a Binary Classification target\n",
        "# (0 = Below Average Price, 1 = Above Average Price)\n",
        "median_price = data['Property_Value_AUD_K'].median()\n",
        "y_visual = (data['Property_Value_AUD_K'] > median_price).astype(int).values\n",
        "\n",
        "# 3. Train the 2D Decision Tree Classifier\n",
        "clf_2d = DecisionTreeClassifier(max_depth=3, random_state=42)\n",
        "clf_2d.fit(X_visual, y_visual)\n",
        "\n",
        "# 4. Define boundaries for the meshgrid based on the property ranges\n",
        "x_min, x_max = X_visual[:, 0].min() - 1.0, X_visual[:, 0].max() + 1.0  # Distance axis\n",
        "y_min, y_max = X_visual[:, 1].min() - 10.0, X_visual[:, 1].max() + 10.0 # Floor Area axis\n",
        "\n",
        "# Create step ranges scaled correctly for continuous spatial data\n",
        "xx, yy = np.meshgrid(np.arange(x_min, x_max, 0.1),\n",
        "                     np.arange(y_min, y_max, 1.0))\n",
        "\n",
        "# 5. Predict region values across the grid\n",
        "Z = clf_2d.predict(np.c_[xx.ravel(), yy.ravel()])\n",
        "Z = Z.reshape(xx.shape)\n",
        "\n",
        "# Colormaps (Light tints for background, solid colors for properties)\n",
        "cmap_background = ListedColormap(['#FFAAAA', '#AAFFAA'])  # Light Red (Below Median), Light Green (Above Median)\n",
        "cmap_points = ['red', 'green']                            # Dark Red (Below), Dark Green (Above)\n",
        "\n",
        "# 6. Plotting\n",
        "plt.figure(figsize=(11, 7))\n",
        "plt.contourf(xx, yy, Z, alpha=0.4, cmap=cmap_background)\n",
        "\n",
        "# Note: No jitter is needed here because continuous data doesn't overlap perfectly like categories do!\n",
        "for class_value, color, label in zip([0, 1], cmap_points, ['Below Median Price', 'Above Median Price']):\n",
        "    mask = (y_visual == class_value)\n",
        "    plt.scatter(X_visual[mask, 0],\n",
        "                X_visual[mask, 1],\n",
        "                c=color, label=label, edgecolor='k', s=60, alpha=0.85, zorder=3)\n",
        "\n",
        "# 7. Layout Customization for Australian Real Estate Context\n",
        "plt.title(f\"Property Classification Boundaries (Median Threshold: ${median_price:.1f}k AUD)\", fontsize=14, fontweight='bold')\n",
        "plt.xlabel(\"Distance to CBD (KM)\", fontsize=12)\n",
        "plt.ylabel(\"Floor Area (SqM)\", fontsize=12)\n",
        "plt.legend(loc='upper right', frameon=True, shadow=True)\n",
        "plt.grid(True, linestyle='--', alpha=0.4)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
